NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/autocheckpoint?schema=public"
JWT_ACCESS_SECRET=change-me-access-min-32-chars-long-secret
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-long-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
# Optional: comma-separated origins for production
# TRUST_PROXY=1

# Customer reschedule/cancel: must be at least this many hours before start (default 24)
APPOINTMENT_CHANGE_MIN_HOURS=24

# Default appointment slot length in minutes
DEFAULT_APPOINTMENT_DURATION_MINUTES=60

# SMTP (optional). If unset, password reset URL is logged in development.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com
