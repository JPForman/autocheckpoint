generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  EMPLOYEE
  ADMIN
}

enum AppointmentStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELED
  NO_SHOW
}

enum TowJobStatus {
  PENDING
  EN_ROUTE
  VEHICLE_LOADED
  IN_TRANSIT
  DELIVERED
  CANCELED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  role         UserRole @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens          RefreshToken[]
  passwordResetTokens    PasswordResetToken[]
  vehicles                 Vehicle[]
  appointmentsAsCustomer Appointment[]        @relation("CustomerAppointments")
  appointmentsAsEmployee Appointment[]        @relation("AssignedEmployee")
  employeeAvailability   EmployeeAvailability[]
  towJobsAsCustomer      TowJob[]             @relation("TowJobCustomer")
  towJobsCreated         TowJob[]             @relation("TowJobCreatedBy")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Vehicle {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  make         String
  model        String
  year         Int
  vin          String?
  licensePlate String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointments Appointment[]
  towJobs      TowJob[]

  @@index([userId])
}

model Appointment {
  id                 String            @id @default(cuid())
  customerId         String
  customer           User              @relation("CustomerAppointments", fields: [customerId], references: [id], onDelete: Cascade)
  vehicleId          String
  vehicle            Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  startsAt           DateTime
  endsAt             DateTime
  serviceType        String
  status             AppointmentStatus @default(SCHEDULED)
  notes              String?
  customerNotes      String?
  assignedEmployeeId String?
  assignedEmployee   User?             @relation("AssignedEmployee", fields: [assignedEmployeeId], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([customerId, startsAt])
  @@index([startsAt])
  @@index([status])
}

model TowJob {
  id               String       @id @default(cuid())
  vehicleId        String?
  vehicle          Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  vehicleDesc      String?
  customerId       String?
  customer         User?        @relation("TowJobCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  createdById      String
  createdBy        User         @relation("TowJobCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  status           TowJobStatus @default(PENDING)
  notes            String?
  pickupLat        Float
  pickupLng        Float
  pickupLabel      String?
  destinationLat   Float
  destinationLng   Float
  destinationLabel String?
  currentLat       Float?
  currentLng       Float?
  currentUpdatedAt DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([createdById])
}

model EmployeeAvailability {
  id          String @id @default(cuid())
  employeeId  String
  employee    User   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  startMinute Int
  endMinute   Int

  @@unique([employeeId, dayOfWeek, startMinute, endMinute])
  @@index([employeeId])
}
